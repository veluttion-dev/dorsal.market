{
  "info": {
    "_postman_id": "f70a5a1a-b640-49b5-8b32-36f53f0db945",
    "name": "Dorsales API - Transaction Bounded Context",
    "description": "Postman collection for transaction bounded context REST endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "auth_token",
      "value": ""
    },
    {
      "key": "user_id",
      "value": "11111111-1111-4111-8111-111111111111"
    },
    {
      "key": "buyer_id",
      "value": "22222222-2222-4222-8222-222222222222"
    },
    {
      "key": "seller_id",
      "value": "33333333-3333-4333-8333-333333333333"
    },
    {
      "key": "admin_user_id",
      "value": "44444444-4444-4444-8444-444444444444"
    },
    {
      "key": "dorsal_id",
      "value": "55555555-5555-4555-8555-555555555555"
    },
    {
      "key": "transaction_id",
      "value": "66666666-6666-4666-8666-666666666666"
    },
    {
      "key": "dispute_id",
      "value": "77777777-7777-4777-8777-777777777777"
    },
    {
      "key": "seller_problem_report_id",
      "value": "88888888-8888-4888-8888-888888888888"
    },
    {
      "key": "proof_file_url",
      "value": "https://example.com/proofs/transfer-proof.pdf"
    },
    {
      "key": "internal_timeout_secret",
      "value": "change-me"
    },
    {
      "key": "stripe_signature",
      "value": "t=timestamp,v1=signature"
    }
  ],
  "item": [
    {
      "name": "Purchase",
      "item": [
        {
          "name": "Onboard Seller",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{seller_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/sellers/onboard",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "sellers",
                "onboard"
              ]
            },
            "description": "Starts Stripe Connect onboarding for a seller."
          },
          "response": []
        },
        {
          "name": "Reserve Listing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dorsal_id\": \"{{dorsal_id}}\",\n  \"buyer_id\": \"{{buyer_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions"
              ]
            },
            "description": "Creates a transaction reservation and Stripe PaymentIntent."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tracking",
      "item": [
        {
          "name": "Get Buyer Transaction Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/buyer/{{transaction_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "buyer",
                "{{transaction_id}}"
              ]
            },
            "description": "Returns buyer-facing transaction detail for the authenticated buyer."
          },
          "response": []
        },
        {
          "name": "Get Seller Transaction Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/seller/{{transaction_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "seller",
                "{{transaction_id}}"
              ]
            },
            "description": "Returns seller-facing transaction detail for the authenticated seller."
          },
          "response": []
        },
        {
          "name": "Get Proof Upload URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seller_id\": \"{{seller_id}}\",\n  \"content_type\": \"application/pdf\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/proof-upload-url",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "proof-upload-url"
              ]
            },
            "description": "Creates a pre-signed upload URL for seller transfer proof."
          },
          "response": []
        },
        {
          "name": "Acknowledge Transfer In Progress",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"seller_id\": \"{{seller_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/transfer-in-progress",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "transfer-in-progress"
              ]
            },
            "description": "Marks the transfer as in progress."
          },
          "response": []
        },
        {
          "name": "Upload Proof File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/upload-proof",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "upload-proof"
              ]
            },
            "description": "Uploads transfer proof as multipart/form-data for the authenticated seller."
          },
          "response": []
        },
        {
          "name": "Submit Proof URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"proof_file_url\": \"{{proof_file_url}}\",\n  \"seller_id\": \"{{seller_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/proof",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "proof"
              ]
            },
            "description": "Submits an already-uploaded proof file URL."
          },
          "response": []
        },
        {
          "name": "Confirm Transfer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buyer_id\": \"{{buyer_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/confirm",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "confirm"
              ]
            },
            "description": "Confirms the transfer from the buyer side."
          },
          "response": []
        },
        {
          "name": "Open Dispute",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"buyer_id\": \"{{buyer_id}}\",\n  \"reason\": \"The transfer details do not match the agreed transaction.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/dispute",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "dispute"
              ]
            },
            "description": "Opens a buyer dispute for a transaction."
          },
          "response": []
        },
        {
          "name": "Create Seller Problem Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "category",
                  "value": "race_rejected_transfer",
                  "type": "text",
                  "description": "Allowed: buyer_data_issue, race_rejected_transfer, payment_or_payout_issue, other"
                },
                {
                  "key": "message",
                  "value": "The race organizer rejected the bib transfer after the transaction was completed.",
                  "type": "text"
                },
                {
                  "key": "files",
                  "type": "file",
                  "src": [],
                  "description": "Optional. Max 3 files, 10MB each. Allowed: image/jpeg, image/png, image/webp, application/pdf."
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/v1/transactions/{{transaction_id}}/seller-problem-reports",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transaction_id}}",
                "seller-problem-reports"
              ]
            },
            "description": "Creates a post-final seller support ticket. Only the authenticated seller can create this when the transaction is RELEASED_TO_SELLER or REFUNDED_TO_BUYER."
          },
          "response": []
        }
      ]
    },
    {
      "name": "History",
      "item": [
        {
          "name": "Get My Purchases",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/me/purchases?status=&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "me",
                "purchases"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "description": "Optional technical status filter."
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Lists purchases for the authenticated user."
          },
          "response": []
        },
        {
          "name": "Get My Sales",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/me/sales?status=&limit=20&offset=0",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "me",
                "sales"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "",
                  "description": "Optional technical status filter."
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Lists sales for the authenticated user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Open Disputes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/disputes",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "disputes"
              ]
            },
            "description": "Lists currently open disputes."
          },
          "response": []
        },
        {
          "name": "Resolve Dispute",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_user_id\": \"{{admin_user_id}}\",\n  \"resolution\": \"buyer\",\n  \"notes\": \"Refund the buyer after reviewing the dispute evidence.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/disputes/{{dispute_id}}/resolve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "disputes",
                "{{dispute_id}}",
                "resolve"
              ]
            },
            "description": "Resolves an open dispute. Valid resolution values are `seller` or `buyer`."
          },
          "response": []
        },
        {
          "name": "List Seller Problem Reports",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/admin/seller-problem-reports",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "seller-problem-reports"
              ]
            },
            "description": "Lists active seller problem reports with status open or in_review."
          },
          "response": []
        },
        {
          "name": "Start Seller Problem Report Review",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_user_id\": \"{{admin_user_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/seller-problem-reports/{{seller_problem_report_id}}/review",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "seller-problem-reports",
                "{{seller_problem_report_id}}",
                "review"
              ]
            },
            "description": "Moves an open seller problem report to in_review."
          },
          "response": []
        },
        {
          "name": "Resolve Seller Problem Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"admin_user_id\": \"{{admin_user_id}}\",\n  \"resolution_notes\": \"Support reviewed the seller report and closed the ticket.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admin/seller-problem-reports/{{seller_problem_report_id}}/resolve",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "admin",
                "seller-problem-reports",
                "{{seller_problem_report_id}}",
                "resolve"
              ]
            },
            "description": "Resolves a seller problem report with admin notes. This does not mutate transaction or payment state."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Internal",
      "item": [
        {
          "name": "Handle Timeout - Expire Reservation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-internal-secret",
                "value": "{{internal_timeout_secret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"expire_reservation\",\n  \"transaction_id\": \"{{transaction_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/internal/timeouts",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "internal",
                "timeouts"
              ]
            },
            "description": "Processes an internal timeout. Other supported type values are `seller_deadline` and `buyer_deadline`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe Webhook - Payment Intent Succeeded",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "stripe-signature",
                "value": "{{stripe_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_payment_intent_succeeded\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_123\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhooks/stripe",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webhooks",
                "stripe"
              ]
            },
            "description": "Stripe webhook endpoint. The body must match the configured Stripe webhook signing secret when signature verification is enabled."
          },
          "response": []
        },
        {
          "name": "Stripe Webhook - Account Updated",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "stripe-signature",
                "value": "{{stripe_signature}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_account_updated\",\n  \"type\": \"account.updated\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"acct_123\",\n      \"charges_enabled\": true\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhooks/stripe",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webhooks",
                "stripe"
              ]
            },
            "description": "Example payload for the Stripe Connect account update event."
          },
          "response": []
        }
      ]
    }
  ]
}
