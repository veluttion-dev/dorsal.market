    {
      "name": "Search Dorsals — GET /api/v1/dorsals",
      "description": "UC-04: search, filter, sort and paginate published dorsals.",
      "item": [
        {
          "name": "All published (no filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/dorsals",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dorsals"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('has pagination fields', () => {",
                  "  ['items','total','page','page_size','total_pages'].forEach(f =>",
                  "    pm.expect(body).to.have.property(f));",
                  "});",
                  "pm.test('draft not included', () => {",
                  "  const draft_id = pm.collectionVariables.get('dorsal_id_draft');",
                  "  body.items.forEach(d => pm.expect(d.id).to.not.eql(draft_id));",
                  "});"
                ]
              }
            }
          ]
        },
