    {
      "name": "Dorsal Detail — GET /api/v1/dorsals/{id}",
      "description": "UC-05: full detail view. Only PUBLISHED dorsals are returned. Draft/sold/cancelled return 404.",
      "item": [
        {
          "name": "Detail: Madrid (phone+email visible)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/dorsals/{{dorsal_id_madrid}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "dorsals", "{{dorsal_id_madrid}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const d = pm.response.json();",
                  "pm.test('all required fields present', () => {",
                  "  ['id','seller_id','photo_url','included_items','status','created_at','updated_at']",
                  "    .forEach(f => pm.expect(d).to.have.property(f));",
                  "});",
                  "pm.test('status published', () => pm.expect(d.status).to.eql('published'));",
                  "pm.test('race_name San Silvestre Madrid', () => pm.expect(d.race_name).to.include('Madrid'));",
                  "pm.test('distance 10k', () => pm.expect(d.distance).to.eql('10k'));",
                  "pm.test('price 45', () => pm.expect(parseFloat(d.price_amount)).to.eql(45));",
                  "pm.test('contact_phone visible', () => pm.expect(d.contact_phone).to.eql('612345678'));",
                  "pm.test('contact_email visible', () => pm.expect(d.contact_email).to.eql('seller@example.com'));",
                  "pm.test('included_items.chip true', () => pm.expect(d.included_items.chip).to.be.true);",
                  "pm.test('sale_reason present', () => pm.expect(d.sale_reason).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Detail: Barcelona (phone hidden, email visible)",
