            "body": {
              "mode": "raw",
              "raw": "{\n  \"photo_url\": \"https://example.com/photos/race.jpg\",\n  \"publish\": true,\n  \"race_name\": \"Madrid Corre\",\n  \"bib_number\": \"777\",\n  \"race_date\": \"2027-04-15\",\n  \"location\": \"Madrid\",\n  \"distance\": \"10k\",\n  \"start_corral\": \"D\",\n  \"included_items\": {\n    \"chip\": true,\n    \"shirt\": false,\n    \"bag\": false,\n    \"medal\": true,\n    \"refreshments\": false\n  },\n  \"price_amount\": 35.00,\n  \"payment_methods\": [\"bizum\"],\n  \"contact\": {\n    \"phone\": \"611111111\",\n    \"email\": null,\n    \"phone_visible\": true,\n    \"email_visible\": false\n  },\n  \"sale_reason\": \"Schedule conflict\"\n}"
            }
