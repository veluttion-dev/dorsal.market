    {
      "name": "Seed",
      "description": "Run these requests in order to populate the DB. IDs are saved as collection variables for use in Search and Detail folders.",
      "item": [
        {
          "name": "Seed: San Silvestre Madrid (10k, 45EUR, bizum+paypal)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/dorsals",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{user_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"photo_url\": \"https://example.com/photos/san-silvestre.jpg\",\n  \"publish\": true,\n  \"race_name\": \"San Silvestre Madrid\",\n  \"bib_number\": \"1234\",\n  \"race_date\": \"2026-12-31\",\n  \"location\": \"Madrid\",\n  \"distance\": \"10k\",\n  \"start_corral\": \"B\",\n  \"included_items\": {\n    \"chip\": true,\n    \"shirt\": true,\n    \"bag\": false,\n    \"medal\": true,\n    \"refreshments\": false\n  },\n  \"price_amount\": 45.00,\n  \"payment_methods\": [\"bizum\", \"paypal\"],\n  \"contact\": {\n    \"phone\": \"612345678\",\n    \"email\": \"seller@example.com\",\n    \"phone_visible\": true,\n    \"email_visible\": true\n  },\n  \"sale_reason\": \"I broke my ankle and cannot run\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('status published', () => pm.expect(body.status).to.eql('published'));",
                  "pm.collectionVariables.set('dorsal_id_madrid', body.dorsal_id);",
                  "console.log('dorsal_id_madrid =', body.dorsal_id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Seed: Marato Barcelona (42k, 90EUR, card+paypal)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/dorsals",
